class Solution {
    public int pivotIndex(int[] nums) {
         int rhs =0;
        int lhs=0;

        for(int i=0;i<nums.length;i++)
        {
            rhs+=nums[i];
        }
        for (int i = 0; i<=nums.length-1; i++){
            lhs=lhs + nums[i];
            if (lhs==rhs){
                return i;
    }
            rhs=rhs-nums[i];
        }
        return -1;
    }
}
